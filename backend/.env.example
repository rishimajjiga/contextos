# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=ContextOS
APP_ENV=development               # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-strong-random-secret

# ── Database ───────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (pooled)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Clerk ─────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JWKS endpoint for your Clerk instance
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# ── OpenAI (optional) ─────────────────────────────────────────────────────
# Leave blank to disable embeddings. Search falls back to keyword (ILIKE) mode.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Supabase Storage ──────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_BUCKET=contextos-documents

# ── Razorpay ──────────────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Get from Razorpay Dashboard → Webhooks → your endpoint → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Get from Razorpay Dashboard → Subscriptions → Plans → Plan ID
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxxxxxx
RAZORPAY_TEAM_PLAN_ID=plan_xxxxxxxxxxxxxxxx

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
