# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=ContextOS
APP_ENV=development               # development | production
DEBUG=true
SECRET_KEY=change-me-to-a-strong-random-secret

# ── Database ───────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (pooled)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Clerk ─────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JWKS endpoint for your Clerk instance
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# ── OpenAI (optional) ─────────────────────────────────────────────────────
# Leave blank to disable embeddings. Search falls back to keyword (ILIKE) mode.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Supabase Storage ──────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_BUCKET=contextos-documents

# ── Razorpay ──────────────────────────────────────────────────────────────
# API keys — get from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* in dev, rzp_live_* in production.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx       # NEVER put this in the frontend!

# Webhook secret — get from Razorpay Dashboard → Settings → Webhooks → your endpoint
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Subscription plan IDs — get from Razorpay Dashboard → Subscriptions → Plans
# Create one plan per billing interval in the Razorpay dashboard, copy the plan_XXXX IDs here.
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxxxxxx          # Monthly Pro (₹499/mo)
RAZORPAY_PRO_ANNUAL_PLAN_ID=plan_xxxxxxxxxxxxxxxx   # Annual Pro  (₹4,499/yr)
RAZORPAY_TEAM_PLAN_ID=plan_xxxxxxxxxxxxxxxx         # Monthly Team (₹1,499/mo)
RAZORPAY_TEAM_ANNUAL_PLAN_ID=plan_xxxxxxxxxxxxxxxx  # Annual Team (₹16,999/yr)
RAZORPAY_STUDENT_PLAN_ID=plan_xxxxxxxxxxxxxxxx      # Student (₹199/mo, optional)

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
