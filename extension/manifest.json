{
  "manifest_version": 3,
  "name": "ContextOS — AI Memory",
  "description": "Save and inject memory across Claude, ChatGPT, Gemini, Perplexity, Copilot, Mistral, and Grok",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "scripting", "alarms", "tabs", "windows"],
  "host_permissions": [
    "http://localhost/*",
    "https://*.run.app/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.mistral.ai/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://poe.com/*",
    "https://huggingface.co/*",
    "https://groq.com/*",
    "https://console.groq.com/*",
    "https://coral.cohere.com/*",
    "https://you.com/*",
    "https://openrouter.ai/*",
    "https://chat.deepseek.com/*",
    "https://kagi.com/*",
    "https://vscode.dev/*",
    "https://github.dev/*",
    "https://github.com/*",
    "https://lovable.dev/*",
    "https://replit.com/*",
    "https://bolt.new/*",
    "https://stackblitz.com/*",
    "https://chat.qwenlm.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/connect-extension*",
        "http://localhost:5174/connect-extension*"
      ],
      "js": ["connect.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://poe.com/*",
        "https://huggingface.co/*",
        "https://groq.com/*",
        "https://console.groq.com/*",
        "https://coral.cohere.com/*",
        "https://you.com/*",
        "https://openrouter.ai/*",
        "https://chat.deepseek.com/*",
        "https://kagi.com/*",
        "https://vscode.dev/*",
        "https://github.dev/*",
        "https://github.com/*",
        "https://lovable.dev/*",
        "https://replit.com/*",
        "https://bolt.new/*",
        "https://stackblitz.com/*",
        "https://chat.qwenlm.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
