{
  "manifest_version": 3,
  "name": "ContextOS — Second Brain",
  "description": "Remember everything. Save conversations, projects, prompts, and knowledge across AI tools.",
  "version": "2.1.1",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://app.contextos.dev/*",
    "https://contextos-eta.vercel.app/*",
    "https://contextos-production-d82a.up.railway.app/*",
    "https://*.run.app/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.mistral.ai/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://poe.com/*",
    "https://huggingface.co/*",
    "https://groq.com/*",
    "https://console.groq.com/*",
    "https://coral.cohere.com/*",
    "https://you.com/*",
    "https://openrouter.ai/*",
    "https://chat.deepseek.com/*",
    "https://kagi.com/*",
    "https://vscode.dev/*",
    "https://github.dev/*",
    "https://github.com/*",
    "https://lovable.dev/*",
    "https://replit.com/*",
    "https://bolt.new/*",
    "https://stackblitz.com/*",
    "https://chat.qwenlm.ai/*",
    "https://cursor.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/connect-extension*",
        "http://localhost:5174/connect-extension*",
        "https://app.contextos.dev/connect-extension*",
        "https://contextos-eta.vercel.app/connect-extension*"
      ],
      "js": [
        "connect.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://app.contextos.dev/*",
        "https://contextos-eta.vercel.app/*"
      ],
      "js": [
        "website-bridge.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "exclude_matches": [
        "https://chromewebstore.google.com/*",
        "https://chrome.google.com/webstore/*",
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://app.contextos.dev/*",
        "https://contextos-eta.vercel.app/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
