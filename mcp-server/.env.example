# ContextOS MCP Server — environment variables
# Copy this file to .env and fill in your values

# Base URL of the ContextOS backend
# Local dev:  http://localhost:8000
# Production: https://your-backend.railway.app
CONTEXTOS_API_URL=http://localhost:8000

# API key generated from the ContextOS dashboard → API Keys page
CONTEXTOS_API_KEY=ctxos_your_key_here

# Optional: name shown in the ContextOS dashboard under "Connected tools"
CONTEXTOS_TOOL_NAME=contextos-mcp
